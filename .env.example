# Application
APP_NAME=RINNSAN_WEB
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-project.vercel.app
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Database (cần SQL Server cloud — Vercel không chạy SQL Server local)
DB_TYPE=sqlsrv
DB_HOST=your-db-host
DB_PORT=1433
DB_DATABASE=RinnSanCF
DB_USERNAME=your-username
DB_PASSWORD=your-password
DB_CHARSET=utf8mb4
DB_TRUSTED_CONNECTION=no

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Security
ENCRYPTION_KEY=change-this-to-a-random-secret

# Frontend build
# VITE_API_URL=http://localhost:8000
VITE_USE_MOCK=true
